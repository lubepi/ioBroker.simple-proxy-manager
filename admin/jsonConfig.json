{
  "type": "tabs",
  "items": {
    "_general": {
      "type": "panel",
      "label": "General",
      "items": {
        "_serverHeader": {
          "type": "header",
          "text": "Server-Ports",
          "size": 4,
          "sm": 12
        },
        "httpsPort": {
          "type": "number",
          "label": "HTTPS Port",
          "sm": 12,
          "md": 4,
          "min": 1,
          "max": 65535,
          "help": "Port for the HTTPS reverse proxy (default: 443)."
        },
        "httpPort": {
          "type": "number",
          "label": "HTTP Port",
          "sm": 12,
          "md": 4,
          "min": 0,
          "max": 65535,
          "help": "Port for the HTTP server (default: 80). Backends without a certificate are served directly here. Backends with a certificate are redirected to HTTPS."
        },
        "acmePort": {
          "type": "number",
          "label": "ACME Adapter Port",
          "sm": 12,
          "md": 4,
          "min": 0,
          "help": "Internal port of the ACME adapter for HTTP-01 challenge forwarding. 0 = disabled."
        },
        "_securityHeader": {
          "type": "header",
          "text": "Security",
          "size": 4,
          "sm": 12
        },
        "enableHSTS": {
          "type": "checkbox",
          "label": "Enable HSTS (Strict-Transport-Security)",
          "sm": 12,
          "md": 4
        },
        "hstsMaxAge": {
          "type": "number",
          "label": "HSTS max-age (seconds)",
          "sm": 12,
          "md": 4,
          "min": 0,
          "help": "Default: 31536000 (1 year)"
        },
        "_certHeader": {
          "type": "header",
          "text": "Certificate Monitoring",
          "size": 4,
          "sm": 12
        },
        "certCheckHours": {
          "type": "number",
          "label": "Check interval (hours)",
          "sm": 12,
          "md": 4,
          "min": 1,
          "help": "How often certificates are checked for changes. SNI contexts are automatically updated on renewal."
        },
        "certWarnDays": {
          "type": "number",
          "label": "Expiry warning (days)",
          "sm": 12,
          "md": 4,
          "min": 0,
          "help": "Log a warning when a certificate expires in less than X days. 0 = disabled."
        },
        "_loggingHeader": {
          "type": "header",
          "text": "Logging",
          "size": 4,
          "sm": 12
        },
        "logSecurity": {
          "type": "checkbox",
          "label": "Log security events",
          "sm": 12,
          "md": 4,
          "help": "Logs denied access (IP filtering, WebSocket)."
        },
        "logRequests": {
          "type": "checkbox",
          "label": "Log all requests",
          "sm": 12,
          "md": 4,
          "help": "Logs every incoming request (HTTP, HTTPS, WebSocket) with IP, host and URL."
        }
      }
    },
    "_backends": {
      "type": "panel",
      "label": "Backends",
      "items": {
        "_info": {
          "type": "header",
          "text": "Proxy Backends (Virtual Hosts)",
          "size": 4,
          "sm": 12
        },
        "backends": {
          "type": "table",
          "sm": 12,
          "uniqueColumns": ["hostname"],
          "items": [
            {
              "type": "checkbox",
              "attr": "enabled",
              "width": "6%",
              "title": "Active",
              "default": true
            },
            {
              "type": "text",
              "attr": "hostname",
              "width": "18%",
              "title": "Hostname",
              "placeholder": "example.domain.de"
            },
            {
              "type": "text",
              "attr": "target",
              "width": "20%",
              "title": "Target URL",
              "placeholder": "http://127.0.0.1:3000"
            },
            {
              "type": "selectSendTo",
              "command": "getCertificateCollections",
              "attr": "certificate",
              "width": "13%",
              "title": "Certificate"
            },
            {
              "type": "text",
              "attr": "allowedNetworks",
              "width": "25%",
              "title": "Allowed Networks",
              "placeholder": "192.168.0.0/24, fd00::/8"
            },
            {
              "type": "checkbox",
              "attr": "changeOrigin",
              "width": "8%",
              "title": "Change Origin",
              "default": false
            }
          ]
        },
        "_help": {
          "type": "staticText",
          "sm": 12,
          "text": "**Hostname**: Domain pointing to this server via DNS. **Target URL**: Backend address (http://IP:Port). **Certificate**: Certificate from `system.certificates`. With certificate = HTTPS + HTTP\u2192HTTPS redirect. Without certificate = HTTP only (no HTTPS for this host). **Allowed Networks**: Comma-separated CIDR networks/IPs (IPv4 + IPv6). If empty, access is allowed from everywhere. **Change Origin**: Rewrite Host header to target IP."
        }
      }
    }
  }
}
