{
    "extends": "@tsconfig/node22/tsconfig.json",
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "moduleResolution": "node",
        "ignoreDeprecations": "6.0",
        "resolveJsonModule": true,
        "allowJs": true,
        "checkJs": true,
        "noEmit": true,
        "strict": false,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "lib": ["ES2022"]
    },
    "include": [
        "main.js",
        "lib/**/*"
    ],
    "exclude": [
        "node_modules",
        "test",
        "admin"
    ]
}
